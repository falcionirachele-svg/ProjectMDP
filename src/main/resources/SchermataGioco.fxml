<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0"
            prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg126012.Controller.GameControllerFX">
   <VBox alignment="CENTER" prefHeight="500.0" prefWidth="800.0" spacing="20.0" styleClass="main-container"
         AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
         AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
      </padding>
      <effect>
         <DropShadow height="96.5" radius="54.185" width="122.24"/>
      </effect>
      <Label id="titoloGioco" alignment="CENTER" text="IL SIPARIO DELL'AVVENTURA" textAlignment="CENTER"
             textOverrun="CENTER_ELLIPSIS" VBox.vgrow="ALWAYS"/>

      <TextArea fx:id="testoStoria" editable="false" prefHeight="339.0" prefWidth="686.0" wrapText="true"
                VBox.vgrow="ALWAYS"/>

      <HBox alignment="CENTER" prefHeight="143.0" prefWidth="748.0" spacing="50.0" VBox.vgrow="ALWAYS">
         <Button fx:id="bottoneScelta1" mnemonicParsing="false" onAction="#scelta1Click" prefHeight="50.0"
                 prefWidth="200.0" styleClass="scelta-button" text="scelta1">
            <effect>
               <DropShadow blurType="GAUSSIAN" height="35.0" offsetX="4.0" radius="20.75" width="50.0"/>
            </effect>
         </Button>
         <Button fx:id="bottoneScelta2" mnemonicParsing="false" onAction="#scelta2Click" prefHeight="50.0"
                 prefWidth="200.0" styleClass="scelta-button" text="scelta2">
            <effect>
               <DropShadow height="35.0" offsetX="4.0" radius="20.75" width="50.0"/>
            </effect>
         </Button>
         <Button fx:id="bottoneScelta3" mnemonicParsing="false" onAction="#scelta3Click" prefHeight="50.0"
                 prefWidth="200.0" styleClass="scelta-button" text="scelta3">
            <effect>
               <DropShadow height="42.5" offsetX="4.0" radius="22.625" width="50.0"/>
            </effect>
         </Button>
         <Button fx:id="bottoneScelta4" mnemonicParsing="false" onAction="#scelta4Click" prefHeight="50.0"
                 prefWidth="200.0" styleClass="scelta-button" text="scelta4">
            <effect>
               <DropShadow height="46.25" offsetX="4.0" radius="23.5625" width="50.0"/>
            </effect>
